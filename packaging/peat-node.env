# Generic standalone configuration. This is the only environment file read by
# peat-node.service. Configure formation identity and credentials before
# exposing the service beyond this host.
PEAT_NODE_LISTEN=tcp://127.0.0.1:50051
PEAT_NODE_DATA_DIR=/var/lib/peat-node
PEAT_NODE_APP_ID=peat-default
PEAT_NODE_AUTO_SYNC=true

# Generate a Base64-encoded 32-byte formation key with:
#   openssl rand -base64 32
# Use the same secret on every node in the formation, then uncomment and set:
# PEAT_NODE_SHARED_KEY=
