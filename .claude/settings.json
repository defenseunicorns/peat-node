{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit:*)",
            "command": "cargo fmt --check && cargo clippy -- -D warnings",
            "timeout": 120,
            "statusMessage": "Running cargo fmt --check && cargo clippy..."
          }
        ]
      }
    ]
  }
}
